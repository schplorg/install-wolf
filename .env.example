# used by download.sh
ARCHIVE_URL=https://f002.backblazeb2.com/file/foobar

# GPU type: nvidia or amd
GPU=nvidia
NVIDIA_DRIVER_VERSION=535

# Container runtime: docker (nvidia, amd) or podman (amd)
CONTAINER_TOOL=docker

# Physical network adapter on the host (e.g. eth0, ens3)
LAN_ADAPTER=eth0

# Macvlan parent adapter
# - Real LAN server: same as LAN_ADAPTER
# - Cloud server: set to DUMMY_ADAPTER value
MACVLAN_ADAPTER=eth0

# Dummy adapter name (cloud/macvlan only, leave empty for real LAN)
DUMMY_ADAPTER=

# Number of user profiles to create
NUM_PROFILES=4

# Network mode for game containers: exposed or macvlan
# exposed  - simpler, direct join works, no LAN discovery between game instances
# macvlan  - game containers appear as real LAN devices (needed for LAN multiplayer)
NETWORK_MODE=exposed

HOST_IF="macvlan-host0"